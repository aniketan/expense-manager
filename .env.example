APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- AI (Prism: config/ai.php, config/prism.php) ---
# Chat uses Server-Sent Events (SSE) on POST /chat/stream — no Reverb/WebSockets required.
AI_PROVIDER=ollama
AI_MODEL=qwen3.5:9b
# Optional: smaller model for bank-statement row categorization (defaults to AI_MODEL)
# AI_CATEGORIZE_MODEL=
AI_CATEGORIZE_MAX_TOKENS=512
AI_MAX_STEPS=5
AI_MAX_TOKENS=4096
OLLAMA_URL=http://localhost:11434
PRISM_REQUEST_TIMEOUT=120

# Cloud providers (set API key for the provider you use in AI_PROVIDER)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# MCP: Claude Desktop can run `php /path/to/artisan mcp:serve` (stdio JSON-RPC). See app/Console/Commands/McpServerCommand.php.

# Statement import (config/statement.php): preamble max chars for LLM, max CSV rows parsed in PHP
# STATEMENT_PREAMBLE_MAX_CHARS=8192
# STATEMENT_MAX_PARSED_ROWS=5000
